      "Test antes: (5856, 53) | Test después: (5290, 55)\n"
     ]
    }
   ],
   "source": [
    "# Eliminamos filas sin objetivos.\n",
    "train_clean = train.dropna(subset=targets).copy()\n",
    "test_clean = test_full.dropna(subset=targets).copy()\n",
    "\n",
    "print('Train antes:', train.shape, '| Train después:', train_clean.shape)\n",
    "print('Test antes:', test.shape, '| Test después:', test_clean.shape)"
