   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train después de eliminar anomalías: (13787, 87)\n",
      "Test después de eliminar anomalías: (5153, 55)\n"
     ]
    }
   ],
   "source": [
    "train_final = train_clean[~train_anomalies.values].copy()\n",
    "test_final = test_clean[~test_anomalies.values].copy()\n",
    "print('Train después de eliminar anomalías:', train_final.shape)\n",
    "print('Test después de eliminar anomalías:', test_final.shape)"
   ]
