   ],
   "source": [
    "targets = ['rougher.output.recovery', 'final.output.recovery']\n",
    "\n",
    "# Recuperamos los objetivos del conjunto de prueba desde full usando la columna date.\n",
    "test_full = test.merge(full[['date'] + targets], on='date', how='left')\n",
    "\n",
    "# Solo se utilizarán como características las columnas que aparecen en test.\n",
    "# Esto evita usar columnas que no estarían disponibles en un caso real.\n",
    "features_columns = []\n",
    "\n",
    "for column in test.columns:\n",
    "    if column != 'date':\n",
    "        features_columns.append(column)\n",
    "\n",
    "print('Cantidad de características usadas:', len(features_columns))\n",
    "print('Targets:', targets)"
   ]
  },
