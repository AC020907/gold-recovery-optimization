     ]
    }
   ],
   "source": [
    "# Para limpiar test con el mismo criterio, agregamos desde full las columnas necesarias\n",
    "# solo para detectar anomalías. Estas columnas no se usarán como features del modelo.\n",
    "anomaly_columns = ['date']\n",
    "\n",
    "for prefix in stages_total.values():\n",
    "    for substance in ['au', 'ag', 'pb', 'sol']:\n",
    "        column = prefix + '_' + substance\n",
    "        if column in full.columns:\n",
    "            anomaly_columns.append(column)\n",
    "\n",
    "test_anomaly_data = test_clean.merge(full[anomaly_columns], on='date', how='left')\n",
    "test_anomalies = get_anomaly_mask(test_anomaly_data)\n",
    "\n",
    "print('Anomalías en test:', test_anomalies.sum())\n",
    "print('Porcentaje de anomalías en test:', test_anomalies.mean() * 100)"
   ]
