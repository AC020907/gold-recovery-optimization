   "source": [
    "### 2.3. Concentraciones totales y eliminación de anomalías"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
