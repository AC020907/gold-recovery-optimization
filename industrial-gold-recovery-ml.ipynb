   "source": [
    "def total_concentration(data, prefix):\n",
    "    columns = []\n",
    "    for substance in ['au', 'ag', 'pb', 'sol']:\n",
    "        column = prefix + '_' + substance\n",
    "        if column in data.columns:\n",
    "            columns.append(column)\n",
    "    return data[columns].sum(axis=1)\n",
    "\n",
    "stages_total = {\n",
    "    'Materia prima': 'rougher.input.feed',\n",
    "    'Concentrado rougher': 'rougher.output.concentrate',\n",
    "    'Concentrado final': 'final.output.concentrate'\n",
    "}\n",
    "\n",
    "for stage_name, prefix in stages_total.items():\n",
    "    total = total_concentration(train_clean, prefix)\n",
    "    plt.hist(total, bins=60)\n",
    "    plt.title('Concentración total - ' + stage_name)\n",
    "    plt.xlabel('Concentración total')\n",
    "    plt.ylabel('Frecuencia')\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Anomalías en train: 362\n",
      "Porcentaje de anomalías en train: 2.5584846985652696\n"
     ]
    }
   ],
   "source": [
    "ANOMALY_LIMIT = 5\n",
    "\n",
    "def get_anomaly_mask(data):\n",
    "    mask = pd.Series(False, index=data.index)\n",
    "    for prefix in stages_total.values():\n",
    "        if prefix + '_au' in data.columns:\n",
    "            total = total_concentration(data, prefix)\n",
    "            mask = mask | (total < ANOMALY_LIMIT)\n",
    "    return mask\n",
    "\n",
    "train_anomalies = get_anomaly_mask(train_clean)\n",
    "\n",
    "print('Anomalías en train:', train_anomalies.sum())\n",
    "print('Porcentaje de anomalías en train:', train_anomalies.mean() * 100)"
   ]
  },
  {
   "cell_type": "code",
