   "source": [
    "# Rellenamos valores ausentes con los valores cercanos en el tiempo.\n",
    "# Primero usamos ffill y luego bfill por si quedan nulos al inicio.\n",
    "train_clean[features_columns] = train_clean[features_columns].ffill().bfill()\n",
    "test_clean[features_columns] = test_clean[features_columns].ffill().bfill()\n",
    "\n",
    "print('Nulos en features de train:', train_clean[features_columns].isna().sum().sum())\n",
